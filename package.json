  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Maninae/real-time-travel-in-the-bay/issues"
  },
  "homepage": "https://github.com/Maninae/real-time-travel-in-the-bay#readme",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "private": true
